{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Omiga",
  "version": "2.0.0",
  "identifier": "com.omiga.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Omiga",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "maximized": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost blob: data: file:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:* https://*; worker-src 'self' blob:; frame-src 'self' blob: data: https: http:; media-src 'self' blob: data: file:; object-src 'none'; base-uri 'self'",
      "dangerousDisableAssetCspModification": false,
      "capabilities": [
        {
          "identifier": "default-capability",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "opener:default",
            "dialog:default",
            "core:path:default",
            "core:window:default",
            "notification:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "appimage",
      "deb",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI coding assistant",
    "longDescription": "An IDE-like AI coding assistant with file operations, search, and session persistence",
    "resources": {
      "bundled_plugins": "bundled_plugins",
      "omiga-plugins": "omiga-plugins"
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  }
}
