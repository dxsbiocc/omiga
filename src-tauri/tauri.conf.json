{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Omiga",
  "version": "0.2.0",
  "identifier": "com.omiga.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Omiga",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "maximized": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false,
      "capabilities": [
        {
          "identifier": "default-capability",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "opener:default",
            "dialog:default",
            "core:path:default",
            "core:window:default",
            "notification:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "appimage",
      "deb",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI coding assistant",
    "longDescription": "An IDE-like AI coding assistant with file operations, search, and session persistence",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "11.0",
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  }
}