{
  "name": "public-dataset-sources",
  "version": "0.1.0",
  "description": "Local subprocess retrieval plugin for public biomedical dataset sources.",
  "retrieval": {
    "protocolVersion": 1,
    "runtime": {
      "command": "./bin/public_dataset_sources.py",
      "args": [],
      "cwd": ".",
      "idleTtlMs": 60000,
      "requestTimeoutMs": 30000,
      "cancelGraceMs": 750,
      "concurrency": 1
    },
    "sources": [
      {
        "id": "biosample",
        "category": "dataset",
        "label": "NCBI BioSample",
        "description": "Sample metadata via NCBI E-utilities and Datasets BioSample report APIs.",
        "aliases": [
          "bio_sample",
          "biosamples",
          "ncbi_biosample",
          "sample_metadata"
        ],
        "subcategories": ["sample_metadata"],
        "capabilities": ["search", "query", "fetch"],
        "requiredCredentialRefs": [],
        "optionalCredentialRefs": [
          "pubmed_api_key",
          "pubmed_email",
          "pubmed_tool_name"
        ],
        "riskLevel": "low",
        "riskNotes": [
          "Read-only public NCBI APIs; optional NCBI credentials are projected only when configured."
        ],
        "defaultEnabled": false,
        "replacesBuiltin": true,
        "parameters": [
          {
            "name": "retmax",
            "type": "number",
            "description": "Maximum BioSample records to request from ESearch."
          }
        ]
      },
      {
        "id": "arrayexpress",
        "category": "dataset",
        "label": "ArrayExpress",
        "description": "Functional genomics studies via EMBL-EBI BioStudies ArrayExpress collection.",
        "aliases": [
          "array_express",
          "ae",
          "ebi_arrayexpress",
          "biostudies_arrayexpress",
          "functional_genomics"
        ],
        "subcategories": ["expression"],
        "capabilities": ["search", "query", "fetch"],
        "requiredCredentialRefs": [],
        "optionalCredentialRefs": [],
        "riskLevel": "low",
        "riskNotes": [
          "Read-only public EMBL-EBI BioStudies APIs."
        ],
        "defaultEnabled": false,
        "replacesBuiltin": true,
        "parameters": [
          {
            "name": "limit",
            "type": "number",
            "description": "Maximum ArrayExpress/BioStudies records to request."
          }
        ]
      },
      {
        "id": "ncbi_datasets",
        "category": "dataset",
        "label": "NCBI Datasets",
        "description": "Genome assembly reports and download summaries via NCBI Datasets v2.",
        "aliases": [
          "ncbi_dataset",
          "ncbi_genome",
          "ncbi_genomes",
          "ncbi_assembly",
          "genome_datasets"
        ],
        "subcategories": ["genome"],
        "capabilities": ["search", "query", "fetch"],
        "requiredCredentialRefs": [],
        "optionalCredentialRefs": [
          "pubmed_api_key"
        ],
        "riskLevel": "low",
        "riskNotes": [
          "Read-only NCBI Datasets API; optional My NCBI API key is projected as an API header only when configured."
        ],
        "defaultEnabled": false,
        "replacesBuiltin": true,
        "parameters": [
          {
            "name": "mode",
            "type": "string",
            "description": "Lookup mode: accession, taxon, bioproject, biosample, wgs, or assembly_name."
          },
          {
            "name": "page_size",
            "type": "number",
            "description": "Maximum genome assembly reports to request."
          }
        ]
      },
      {
        "id": "gtex",
        "category": "dataset",
        "label": "GTEx",
        "description": "Human gene and tissue-expression metadata via GTEx Portal API v2.",
        "aliases": [
          "genotype_tissue_expression",
          "tissue_expression"
        ],
        "subcategories": ["expression"],
        "capabilities": ["search", "query", "fetch"],
        "requiredCredentialRefs": [],
        "optionalCredentialRefs": [],
        "riskLevel": "low",
        "riskNotes": [
          "Read-only GTEx Portal API."
        ],
        "defaultEnabled": false,
        "replacesBuiltin": true,
        "parameters": [
          {
            "name": "gencodeVersion",
            "type": "string",
            "description": "GTEx GENCODE version, default v26."
          },
          {
            "name": "genomeBuild",
            "type": "string",
            "description": "GTEx genome build, default GRCh38/hg38."
          }
        ]
      },
      {
        "id": "cbioportal",
        "category": "dataset",
        "label": "cBioPortal",
        "description": "Cancer genomics study metadata via the cBioPortal REST API.",
        "aliases": [
          "cbio_portal",
          "cbio",
          "cancer_genomics",
          "tcga"
        ],
        "subcategories": ["cancer_genomics"],
        "capabilities": ["search", "query", "fetch"],
        "requiredCredentialRefs": [],
        "optionalCredentialRefs": [],
        "riskLevel": "low",
        "riskNotes": [
          "Read-only public cBioPortal study API."
        ],
        "defaultEnabled": false,
        "replacesBuiltin": true,
        "parameters": [
          {
            "name": "pageSize",
            "type": "number",
            "description": "Maximum studies to request from cBioPortal."
          }
        ]
      }
    ]
  },
  "interface": {
    "displayName": "Public Dataset Sources",
    "shortDescription": "BioSample, ArrayExpress, NCBI Datasets, GTEx, and cBioPortal as local retrieval plugins",
    "longDescription": "Moves public dataset data-source execution for BioSample, ArrayExpress, NCBI Datasets, GTEx, and cBioPortal behind Omiga's local search/query/fetch subprocess route protocol.",
    "developerName": "Omiga",
    "category": "Retrieval",
    "capabilities": [
      "Dataset",
      "Retrieval",
      "Local Subprocess",
      "Search",
      "Query",
      "Fetch"
    ],
    "brandColor": "#3B82F6",
    "defaultPrompt": [
      "Search BioSample for liver single-cell RNA-seq samples.",
      "Fetch BioSample SAMN04271175 through the dataset plugin.",
      "Search NCBI Datasets or GTEx through the public dataset plugin."
    ]
  }
}
