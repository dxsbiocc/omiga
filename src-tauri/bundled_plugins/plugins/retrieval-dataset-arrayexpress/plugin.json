{
  "name": "retrieval-dataset-arrayexpress",
  "version": "0.1.0",
  "description": "Runs ArrayExpress/BioStudies search/query/fetch through Omiga local subprocess routing.",
  "retrieval": {
    "protocolVersion": 1,
    "runtime": {
      "command": "./scripts/retrieval_dataset_arrayexpress.py",
      "args": [],
      "env": {
        "OMIGA_RETRIEVAL_SOURCE_IDS": "arrayexpress",
        "OMIGA_RETRIEVAL_PLUGIN_NAME": "retrieval-dataset-arrayexpress"
      },
      "cwd": ".",
      "idleTtlMs": 60000,
      "requestTimeoutMs": 30000,
      "cancelGraceMs": 750,
      "concurrency": 1
    },
    "resources": [
      {
        "id": "arrayexpress",
        "category": "dataset",
        "label": "ArrayExpress",
        "description": "Functional genomics studies via EMBL-EBI BioStudies ArrayExpress collection.",
        "aliases": [
          "array_express",
          "ae",
          "ebi_arrayexpress",
          "biostudies_arrayexpress",
          "functional_genomics"
        ],
        "subcategories": [
          "expression"
        ],
        "capabilities": [
          "search",
          "query",
          "fetch"
        ],
        "requiredCredentialRefs": [],
        "optionalCredentialRefs": [],
        "riskLevel": "low",
        "riskNotes": [
          "Read-only public EMBL-EBI BioStudies APIs."
        ],
        "defaultEnabled": false,
        "replacesBuiltin": true,
        "parameters": [
          {
            "name": "limit",
            "type": "number",
            "description": "Maximum ArrayExpress/BioStudies records to request."
          }
        ]
      }
    ]
  },
  "interface": {
    "displayName": "ArrayExpress Retrieval Resource",
    "shortDescription": "ArrayExpress/BioStudies as a local retrieval plugin",
    "longDescription": "Runs ArrayExpress/BioStudies search/query/fetch through Omiga local subprocess routing.",
    "developerName": "Omiga",
    "category": "Retrieval",
    "capabilities": [
      "Dataset",
      "Retrieval",
      "Local Subprocess",
      "Search",
      "Query",
      "Fetch"
    ],
    "brandColor": "#7C3AED",
    "defaultPrompt": [
      "Search ArrayExpress for single-cell datasets.",
      "Fetch an E-MTAB accession through the ArrayExpress plugin."
    ]
  }
}
