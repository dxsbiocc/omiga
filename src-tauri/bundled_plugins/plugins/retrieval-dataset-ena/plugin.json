{
  "name": "retrieval-dataset-ena",
  "version": "0.1.0",
  "description": "Runs European Nucleotide Archive search/query/fetch routes through Omiga local subprocess routing.",
  "retrieval": {
    "protocolVersion": 1,
    "runtime": {
      "command": "./scripts/retrieval_dataset_ena.py",
      "args": [],
      "env": {
        "OMIGA_RETRIEVAL_SOURCE_IDS": "ena,ena_run,ena_experiment,ena_sample,ena_analysis,ena_assembly,ena_sequence",
        "OMIGA_RETRIEVAL_PLUGIN_NAME": "retrieval-dataset-ena"
      },
      "cwd": ".",
