          "study",
          "read_study",
          "european_nucleotide_archive"
        ],
        "subcategories": [
          "sequencing"
        ],
        "capabilities": [
          "search",
          "query",
          "fetch"
        ],
        "requiredCredentialRefs": [],
        "optionalCredentialRefs": [],
        "riskLevel": "low",
        "riskNotes": [
          "Read-only public EMBL-EBI ENA APIs."
        ],
        "defaultEnabled": false,
        "replacesBuiltin": true,
        "parameters": [
          {
            "name": "limit",
            "type": "number",
            "description": "Maximum ENA records to request."
          }
        ]
      },
