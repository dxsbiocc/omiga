# Omiga Configuration
# Copy to .env and fill in values

# Assistant name (used for trigger pattern @NAME)
ASSISTANT_NAME=Andy

# Whether the assistant has its own WhatsApp number
ASSISTANT_HAS_OWN_NUMBER=false

# Container configuration
CONTAINER_IMAGE=omiga-agent:latest
CONTAINER_TIMEOUT=1800000
CONTAINER_MAX_OUTPUT_SIZE=10485760
MAX_CONCURRENT_CONTAINERS=5

# Timing
IDLE_TIMEOUT=1800000

# Timezone (defaults to system timezone)
# TZ=America/New_York

# Logging
# LOG_LEVEL=info

# ── HTTP API Server ───────────────────────────────────────────────────────────
# REST API for remote management. Disabled if HTTP_API_PORT=0.
# Endpoints: GET /status /groups /chats /tasks, POST /groups, DELETE /groups/{jid}
#            POST /tasks/{id}/run, GET /workspace/backup
# Bind to 0.0.0.0 to expose on the network (use with HTTP_API_TOKEN for auth).
#
# HTTP_API_PORT=7891
# HTTP_API_HOST=127.0.0.1
# HTTP_API_TOKEN=your-secret-token   # optional Bearer token auth

# ── Main Group (Personal Chat) ────────────────────────────────────────────────
# Optional: JID of your personal chat or private group.
# When set, omiga auto-registers it as the "main" group at startup.
# The main group NEVER needs a trigger word — every message goes to the agent.
#
# How to find your JID:
#   Telegram private chat:  "tg:{your_user_id}"  (send /start to @userinfobot)
#   Telegram group:         "tg:{group_chat_id}"  (usually negative, e.g. tg:-1001234567890)
#
# MAIN_GROUP_JID=tg:123456789
# MAIN_GROUP_NAME=My Personal Chat

# ── Telegram Channel ──────────────────────────────────────────────────────────
# Get a token from @BotFather: /newbot
# Then disable privacy mode: @BotFather → /setprivacy → Disable
# so the bot receives all group messages (not just @mentions and commands).
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlmNoPqRsTuVwXyZ

# ── AI Provider ───────────────────────────────────────────────────────────────
# Works with any OpenAI-compatible provider. Set three values:
#
# DeepSeek:
#   AI_API_KEY=sk-...
#   AI_BASE_URL=https://api.deepseek.com/v1
#   AI_MODEL=deepseek-chat
#
# Qwen (Alibaba DashScope):
#   AI_API_KEY=sk-...
#   AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   AI_MODEL=qwen-plus
#
# Minimax:
#   AI_API_KEY=...
#   AI_BASE_URL=https://api.minimax.chat/v1
#   AI_MODEL=abab6.5s-chat
#
# Anthropic (original, use omiga-agent:latest container):
#   ANTHROPIC_API_KEY=sk-ant-...

# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# ── Feishu (Lark) Channel ─────────────────────────────────────────────────────
# Create an app at https://open.feishu.cn/app
# Enable "Bot" capability, subscribe to "im.message.receive_v1" event
# Use WebSocket (长连接) mode — no public IP required
# Install: pip install lark-oapi aiohttp
#
# FEISHU_APP_ID=cli_xxxxx
# FEISHU_APP_SECRET=xxxxxxxx

# ── QQ Channel ────────────────────────────────────────────────────────────────
# Apply at https://q.qq.com/ → Create bot → get App ID and App Secret
# Install: pip install websocket-client aiohttp
#
# QQ_APP_ID=your_app_id
# QQ_APP_SECRET=your_app_secret
# QQ_API_BASE=https://api.sgroup.qq.com   # optional, default is production

# ── Discord Channel ───────────────────────────────────────────────────────────
# 1. https://discord.com/developers/applications → New Application → Bot
# 2. Copy Token; enable "MESSAGE CONTENT INTENT" under Privileged Gateway Intents
# 3. Invite bot: OAuth2 → URL Generator → scopes: bot, permissions: Send Messages
# Install: pip install discord.py>=2.3
# Note: Discord is blocked in China — set DISCORD_HTTP_PROXY if needed
#
# DISCORD_BOT_TOKEN=your_bot_token
# DISCORD_HTTP_PROXY=http://127.0.0.1:7890   # optional, for regions where Discord is blocked
