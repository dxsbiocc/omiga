#!/usr/bin/env Rscript
# Template: scatter/polar-lollipop
# Purpose: Polar lollipop plot for ordered category values.
#
# Migration note:
#   This template migrates OmicsAgent scatter/lollipop_polar from a private
#   JSON ggplot2 DSL into direct, editable R/ggplot2 code. The original
#   data.json has been converted to example.tsv.
#
# Smoke test:
#   Rscript scripts/smoke_templates.R --template scatter/polar-lollipop

plugin_root <- "{{ template.pluginRoot }}"
manifest_dir <- "{{ template.manifestDir }}"
source(file.path(plugin_root, "scripts", "lib", "bootstrap.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "io.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "schema.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "theme.R"))
source_if_exists(file.path(plugin_root, "scripts", "lib", "export.R"))
load_packages(c("ggplot2"))

args <- commandArgs(trailingOnly = TRUE)
arg_or <- function(index, default = "") {
  if (length(args) >= index && nzchar(args[[index]])) args[[index]] else default
}
parse_number_arg <- function(index, default) {
  value <- suppressWarnings(as.numeric(arg_or(index, as.character(default))))
  if (is.na(value)) default else value
}
parse_integer_arg <- function(index, default) {
  value <- suppressWarnings(as.integer(arg_or(index, as.character(default))))
  if (is.na(value)) default else value
}
parse_csv_arg <- function(index, default = "") {
  raw <- arg_or(index, default)
  if (!nzchar(raw) || tolower(raw) == "auto") return(character())
  values <- trimws(strsplit(raw, ",", fixed = TRUE)[[1]])
  values[nzchar(values)]
}
parse_numeric_csv_arg <- function(index, default = "") {
  values <- suppressWarnings(as.numeric(parse_csv_arg(index, default)))
  values[is.finite(values)]
}

input <- arg_or(1, file.path(manifest_dir, "example.tsv"))
outdir <- arg_or(2, file.path(tempdir(), "visualization-r-output"))
config <- list(
  columns = list(
    category = arg_or(3, "age_group"),
    value = arg_or(4, "mean_prev"),
    group = arg_or(5, "group")
  ),
  levels = list(
    categories = parse_csv_arg(6, ""),
    groups = parse_csv_arg(7, "Low,Medium,High")
  ),
  labels = list(title = arg_or(8, "Polar Lollipop Plot")),
  style = list(
    palette = parse_csv_arg(9, "#1aafd0,#2dde98,#ffc168"),
    ring_values = parse_numeric_csv_arg(10, "0,0.1,0.2"),
    inner_radius = parse_number_arg(11, -0.1),
    outer_limit = parse_number_arg(12, 0.3),
    inner_fill = arg_or(13, "#81947a"),
    inner_alpha = parse_number_arg(14, 0.5),
    segment_width = parse_number_arg(15, 0.7),
    point_size_outer = parse_number_arg(16, 5),
    point_size_inner = parse_number_arg(17, 3),
    stroke = parse_number_arg(18, 0.9),
    category_label_size = parse_number_arg(19, 3),
    value_label_size = parse_number_arg(20, 3),
    center_label = arg_or(21, "Age"),
    center_label_size = parse_number_arg(22, 6),
    base_size = parse_number_arg(23, 12)
  )
)
delimiter <- arg_or(24, "auto")
width <- parse_number_arg(25, 5)
height <- parse_number_arg(26, 5)
dpi <- parse_integer_arg(27, 300)

first_seen <- function(x) unique(as.character(x))
label_angle <- function(index, n, offset = 0) {
  angle <- 90 - 360 * (index - 0.5) / n
  out <- ifelse(angle < -90, angle + 180, angle)
  out + offset
}
label_hjust <- function(index, n, hjust = 0.2) {
  angle <- 90 - 360 * (index - 0.5) / n
  ifelse(angle < -90, 1 + hjust, -hjust)
}

prepare_data <- function(df, config) {
  required <- c(config$columns$category, config$columns$value)
  group_col <- resolve_optional_column(df, config$columns$group)
  if (!is.null(group_col)) required <- c(required, group_col)
  validate_columns(df, required, "scatter/polar-lollipop input")
  df <- ensure_numeric_columns(df, config$columns$value, "scatter/polar-lollipop input")
  df$.category_raw <- as.character(df[[config$columns$category]])
  df$.value <- df[[config$columns$value]]
  if (is.null(group_col)) {
    df$.group_raw <- "Value"
  } else {
    df$.group_raw <- as.character(df[[group_col]])
  }
  df <- df[is.finite(df$.value) & nzchar(df$.category_raw) & nzchar(df$.group_raw), , drop = FALSE]
  if (nrow(df) == 0) stop("scatter/polar-lollipop input has no usable rows.", call. = FALSE)
  category_levels <- config$levels$categories
  if (length(category_levels) == 0) category_levels <- first_seen(df$.category_raw)
  group_levels <- config$levels$groups
  if (length(group_levels) == 0) group_levels <- first_seen(df$.group_raw)
  group_levels <- c(group_levels[group_levels %in% df$.group_raw], setdiff(first_seen(df$.group_raw), group_levels))
  df <- df[df$.category_raw %in% category_levels & df$.group_raw %in% group_levels, , drop = FALSE]
  df$.category <- factor(df$.category_raw, levels = category_levels)
  df$.group <- factor(df$.group_raw, levels = group_levels)
  df$.index <- as.numeric(df$.category)
  n <- length(category_levels)
  outer_limit <- config$style$outer_limit
  if (!is.finite(outer_limit) || outer_limit <= max(df$.value, na.rm = TRUE)) {
    outer_limit <- max(df$.value, na.rm = TRUE) * 1.35
  }
  df$.category_label_y <- outer_limit * 0.86
  df$.value_label_y <- df$.value + outer_limit * 0.035
  df$.category_angle <- label_angle(df$.index, n, 0)
  df$.value_angle <- label_angle(df$.index, n, -6)
  df$.category_hjust <- label_hjust(df$.index, n, 0.2)
  df$.value_hjust <- label_hjust(df$.index, n, 0.4)
  list(points = df, category_levels = category_levels, group_levels = group_levels, outer_limit = outer_limit)
}

make_plot <- function(prepared, config) {
  df <- prepared$points
  category_levels <- prepared$category_levels
  group_levels <- prepared$group_levels
  n <- length(category_levels)
  palette <- config$style$palette
  if (length(palette) < length(group_levels)) palette <- rep(palette, length.out = length(group_levels))
  palette <- stats::setNames(palette[seq_along(group_levels)], group_levels)
  ring_values <- config$style$ring_values
  if (length(ring_values) == 0) ring_values <- pretty(c(0, prepared$outer_limit), n = 3)
  band_df <- data.frame(xmin = 0.5, xmax = n + 0.5, ymin = config$style$inner_radius, ymax = 0)
  center_df <- data.frame(x = n / 2 + 0.5, y = config$style$inner_radius * 0.65, label = config$style$center_label)

  ggplot2::ggplot(df, ggplot2::aes(x = .index, y = .value, colour = .group)) +
    ggplot2::geom_rect(
      data = band_df,
      ggplot2::aes(xmin = xmin, xmax = xmax, ymin = ymin, ymax = ymax),
      inherit.aes = FALSE,
      fill = config$style$inner_fill,
      alpha = config$style$inner_alpha,
      colour = NA
    ) +
    ggplot2::geom_hline(yintercept = ring_values, colour = "grey90", linewidth = 0.45) +
    ggplot2::geom_segment(
      ggplot2::aes(xend = .index, y = 0, yend = .value),
      linewidth = config$style$segment_width,
      show.legend = FALSE
    ) +
    ggplot2::geom_point(
      shape = 21,
      size = config$style$point_size_outer,
      stroke = config$style$stroke,
      fill = "white"
    ) +
    ggplot2::geom_point(size = config$style$point_size_inner) +
    ggplot2::geom_text(
      ggplot2::aes(x = .index, y = .category_label_y, label = .category_raw, angle = .category_angle, hjust = .category_hjust),
      inherit.aes = FALSE,
      size = config$style$category_label_size,
      show.legend = FALSE
    ) +
    ggplot2::geom_text(
      ggplot2::aes(x = .index, y = .value_label_y, label = sprintf("%.2f", .value), angle = .value_angle, hjust = .value_hjust),
      inherit.aes = FALSE,
      size = config$style$value_label_size,
      vjust = 2,
      show.legend = FALSE
    ) +
    ggplot2::geom_text(
      data = center_df,
      ggplot2::aes(x = x, y = y, label = label),
      inherit.aes = FALSE,
      size = config$style$center_label_size,
      vjust = 0.5,
      show.legend = FALSE
    ) +
    ggplot2::scale_colour_manual(values = palette, guide = "none") +
    ggplot2::scale_x_continuous(limits = c(0.5, n + 0.5), breaks = seq_len(n), labels = rep("", n), expand = c(0, 0)) +
    ggplot2::scale_y_continuous(limits = c(config$style$inner_radius, prepared$outer_limit), expand = c(0, 0)) +
    ggplot2::coord_polar(theta = "x") +
    ggplot2::labs(title = config$labels$title, x = NULL, y = NULL) +
    ggplot2::theme_void(base_size = config$style$base_size) +
    ggplot2::theme(
      plot.background = ggplot2::element_rect(fill = "white", color = NA),
      panel.background = ggplot2::element_rect(fill = "white", color = NA),
      plot.title = ggplot2::element_text(size = config$style$base_size * 1.15, hjust = 0.5, face = "bold")
    )
}

customize_plot <- function(p, prepared, config) { p }

main <- function() {
  outdir <- ensure_dir(outdir)
  df <- read_table_auto(input, delimiter)
  prepared <- prepare_data(df, config)
  p <- customize_plot(make_plot(prepared, config), prepared, config)
  save_ggplot_outputs(p, outdir, prefix = "figure", width = width, height = height, dpi = dpi, formats = c("png", "pdf"))
  write_tsv(
    data.frame(
      metric = c("template", "rows", "categories", "groups", "value_min", "value_max"),
      value = c("scatter/polar-lollipop", nrow(prepared$points), length(prepared$category_levels), length(prepared$group_levels), min(prepared$points$.value), max(prepared$points$.value))
    ),
    file.path(outdir, "summary.tsv")
  )
  write_outputs_json(outdir, list(template = "scatter/polar-lollipop", rows = nrow(prepared$points), categories = length(prepared$category_levels), groups = prepared$group_levels, value_min = min(prepared$points$.value), value_max = max(prepared$points$.value)))
  write_working_artifacts(outdir, get_current_script(), args)
  cat(sprintf("Saved visualization outputs to %s\n", outdir))
}
main()
